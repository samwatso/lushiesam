---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Hero from '@/components/Hero.astro';
import CTABlock from '@/components/CTABlock.astro';
---

<BaseLayout
  title="About This Archive"
  description="The Lush Kitchen Archive is a fan-maintained archive of Lush Kitchen subscription boxes since 2022. Maintained by Sam (@lushiesam on TikTok)."
>
  <Hero
    title="About This Archive"
    tag="What this site is"
    minimal
  />

  <section class="section">
    <div class="container container--narrow">
      <div class="about-content" data-animate="stagger-children">
        <h3>The archive</h3>
        <p>
          The Lush Kitchen Archive is a fan-maintained archive of Lush Kitchen subscription boxes,
          documented since 2022. Each box includes its full product list, scent notes, nostalgia
          context, and TikTok unboxing video.
        </p>
        <p>
          The goal is simple: create a searchable, lasting record of what arrived in each box, so
          subscribers past and present can look up any month and find exactly what was in it. TikTok
          videos disappear into feeds. This site doesn't.
        </p>

        <h3>About Sam</h3>
        <p>
          Sam (<a href="https://www.tiktok.com/@lushiesam" target="_blank" rel="noopener noreferrer">@lushiesam on TikTok</a>)
          has been a Lush fan since attending Creative Showcase in 2016 and a Kitchen subscriber
          since February 2022. Every month, Sam films an unboxing and documents the box here.
        </p>
        <p>
          This isn't a review site or a brand partnership. It's one fan's effort to keep a thorough
          record of something worth documenting.
        </p>
      </div>
    </div>
  </section>

  <CTABlock
    title="Explore the archive"
    description="Kitchen boxes since 2022, documented and archived."
    primaryLink="/kitchen-boxes/"
    primaryLabel="Kitchen Boxes"
    secondaryLink="/what-is-kitchen/"
    secondaryLabel="What is Kitchen?"
  />
</BaseLayout>

<style>
  .about-content {
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
  }

  .about-content h3 {
    margin-top: var(--space-xl);
    margin-bottom: 0;
  }

  .about-content p {
    color: var(--color-text-secondary);
    font-size: 1.0625rem;
    line-height: 1.85;
    max-width: none;
  }

  .about-content a {
    color: var(--color-green-bright);
  }

  .about-content a:hover {
    color: var(--color-white);
  }
</style>
