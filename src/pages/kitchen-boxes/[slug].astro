---
import { getAllBoxes, renderBoxContent } from '@/lib/content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import ProductList from '@/components/ProductList.astro';
import ScreenshotGallery from '@/components/ScreenshotGallery.astro';
import VideoEmbed from '@/components/VideoEmbed.astro';
import NostalgiaNote from '@/components/NostalgiaNote.astro';
import BoxCard from '@/components/BoxCard.astro';

export async function getStaticPaths() {
  const boxes = await getAllBoxes();
  return boxes.map((box) => ({
    params: { slug: box.id },
    props: { box },
  }));
}

const { box } = Astro.props;
const { data } = box;
const rendered = await renderBoxContent(box);
const Content = rendered.Content;

const allBoxes = (await getAllBoxes())
  .filter((entry) => !entry.data.draft)
  .sort((a, b) => {
    const dateA = a.data.publishedDate?.getTime() ?? 0;
    const dateB = b.data.publishedDate?.getTime() ?? 0;
    return dateB - dateA;
  });

const currentIndex = allBoxes.findIndex((entry) => entry.id === box.id);
const newerBox = currentIndex > 0 ? allBoxes[currentIndex - 1] : undefined;
const olderBox = currentIndex >= 0 ? allBoxes[currentIndex + 1] : undefined;
const relatedBoxes = [newerBox, olderBox].filter(Boolean);
const heroImage = data.groupShot || data.heroImage;
const scentNotes = [...new Set(data.products?.flatMap((product) => product.scent?.split(',').map((note) => note.trim()).filter(Boolean) ?? []) ?? [])];
---

<BaseLayout
  title={data.title}
  description={data.summary}
  ogImage={data.heroImage}
  ogType="article"
>
  <article class="record-page">
    <header class="record-hero">
      <div class="record-media" aria-hidden="true">
        {heroImage ? <img src={heroImage} alt="" /> : <div class="record-fallback"></div>}
      </div>
      <div class="record-shade"></div>

      <div class="container container--wide record-hero-inner">
        <div class="record-title-block" data-animate="fade-up">
          <span class="eyebrow">{data.month} {data.year}</span>
          <h1>{data.title}</h1>
          <p class="lede">{data.summary}</p>
          <div class="record-actions">
            <a href="#products" class="btn btn--primary">View products</a>
            <a href="/kitchen-boxes/" class="btn btn--secondary">All boxes</a>
          </div>
        </div>

        <aside class="record-facts liquid-panel" aria-label="Box facts" data-animate="fade-in">
          <span class="facts-label">Record data</span>
          <dl>
            <div>
              <dt>Month</dt>
              <dd>{data.month}</dd>
            </div>
            <div>
              <dt>Year</dt>
              <dd>{data.year}</dd>
            </div>
            <div>
              <dt>Products</dt>
              <dd>{data.products?.length ?? 0}</dd>
            </div>
            <div>
              <dt>Scent notes</dt>
              <dd>{scentNotes.length}</dd>
            </div>
          </dl>
        </aside>
      </div>
    </header>

    <div class="container container--wide record-layout">
      <aside class="record-sidebar liquid-panel">
        <span class="sidebar-label">On this record</span>
        <nav aria-label="Box page sections">
          <a href="#story">Story</a>
          <a href="#products">Products</a>
          {data.nostalgiaNotes && data.nostalgiaNotes.length > 0 && <a href="#nostalgia">Nostalgia</a>}
          {data.caption && <a href="#caption">Caption</a>}
        </nav>
        {scentNotes.length > 0 && (
          <div class="sidebar-scents">
            {scentNotes.slice(0, 8).map((note, index) => (
              <span class="chip" style={`--chip-color: ${index % 3 === 0 ? 'var(--color-pink)' : index % 3 === 1 ? 'var(--color-blue)' : 'var(--color-gold)'}`}>{note}</span>
            ))}
          </div>
        )}
      </aside>

      <div class="record-main">
        <section id="story" class="record-section record-story liquid-panel" data-animate="fade-up">
          <div class="record-section-heading">
            <span class="section-kicker">Editorial record</span>
            <h2>The month in context</h2>
          </div>

          <VideoEmbed tiktokUrl={data.tiktokUrl} tiktokEmbedId={data.tiktokEmbedId} youtubeId={data.youtubeId} />

          {data.kitchenMenuUrl && (
            <div class="kitchen-menu-link">
              <a href={data.kitchenMenuUrl} target="_blank" rel="noopener noreferrer" class="btn btn--secondary">
                View the Kitchen Menu
              </a>
            </div>
          )}

          {Content ? (
            <div class="box-content prose">
              <Content />
            </div>
          ) : rendered.html ? (
            <div class="box-content prose" set:html={rendered.html} />
          ) : null}

          {data.groupShot && (
            <div class="group-shot" data-animate="scale-up">
              <img src={data.groupShot} alt={`${data.title}, all products`} />
            </div>
          )}
        </section>

        {data.products && data.products.length > 0 && (
          <section id="products" class="record-section" data-animate="fade-up">
            <div class="record-section-heading">
              <span class="section-kicker">Box contents</span>
              <h2>Products in this box</h2>
              <p>{data.products.length} products documented with notes, scent signals and collector context.</p>
            </div>
            <ProductList products={data.products} />
          </section>
        )}

        {data.nostalgiaNotes && data.nostalgiaNotes.length > 0 && (
          <section id="nostalgia" class="record-section">
            <NostalgiaNote notes={data.nostalgiaNotes} />
          </section>
        )}

        {data.screenshots && data.screenshots.length > 0 && (
          <section class="record-section">
            <ScreenshotGallery screenshots={data.screenshots} title="Gallery" />
          </section>
        )}

        {data.caption && (
          <section id="caption" class="record-section caption-block liquid-panel" data-animate="fade-up">
            <div class="record-section-heading">
              <span class="section-kicker">Social caption</span>
              <h2>The caption</h2>
            </div>
            <blockquote class="caption-quote">{data.caption}</blockquote>
            {data.hashtags && data.hashtags.length > 0 && (
              <div class="hashtags">
                {data.hashtags.map((tag) => (
                  <span class="chip">#{tag}</span>
                ))}
              </div>
            )}
          </section>
        )}

        {relatedBoxes.length > 0 && (
          <section class="record-section related-records">
            <div class="record-section-heading">
              <span class="section-kicker">Adjacent records</span>
              <h2>Move through the timeline</h2>
            </div>
            <div class="related-grid">
              {relatedBoxes.map((related) => related && (
                <BoxCard
                  title={related.data.title}
                  slug={related.id}
                  month={related.data.month}
                  year={related.data.year}
                  summary={related.data.summary}
                  heroImage={related.data.heroImage}
                  productCount={related.data.products?.length}
                  products={related.data.products}
                />
              ))}
            </div>
          </section>
        )}
      </div>
    </div>
  </article>
</BaseLayout>

<style>
  .record-page {
    overflow: hidden;
  }

  .record-hero {
    position: relative;
    min-height: 92svh;
    display: flex;
    align-items: end;
    padding: 8rem 0 var(--space-4xl);
  }

  .record-media,
  .record-shade {
    position: absolute;
    inset: 0;
  }

  .record-media img,
  .record-fallback {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transform: scale(1.04);
  }

  .record-fallback {
    background: var(--gradient-hero);
  }

  .record-shade {
    background:
      linear-gradient(180deg, rgba(5, 6, 8, 0.08), rgba(5, 6, 8, 0.38) 42%, rgba(5, 6, 8, 0.96)),
      radial-gradient(circle at 22% 30%, rgba(143, 245, 210, 0.18), transparent 28rem),
      radial-gradient(circle at 80% 24%, rgba(255, 141, 184, 0.2), transparent 25rem),
      radial-gradient(circle at 55% 78%, rgba(169, 140, 255, 0.13), transparent 24rem);
  }

  .record-hero-inner {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: minmax(0, 1fr) 340px;
    gap: var(--space-2xl);
    align-items: end;
  }

  .record-title-block {
    max-width: 940px;
  }

  .record-title-block h1 {
    margin: var(--space-sm) 0 var(--space-lg);
    font-size: clamp(3.25rem, 8vw, 7.5rem);
  }

  .record-actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-md);
    margin-top: var(--space-xl);
  }

  .record-facts {
    border-radius: var(--radius-2xl);
    padding: var(--space-lg);
    overflow: hidden;
  }

  .record-facts::after {
    content: '';
    position: absolute;
    inset: auto -22% -40% 18%;
    height: 64%;
    border-radius: 50%;
    background: radial-gradient(ellipse, rgba(255, 141, 184, 0.13), transparent 68%);
    filter: blur(22px);
    pointer-events: none;
  }

  .facts-label,
  .sidebar-label {
    display: block;
    margin-bottom: var(--space-md);
    color: var(--color-text-muted);
    font-size: 0.7rem;
    font-weight: 900;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .record-facts dl {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-sm);
  }

  .record-facts div {
    padding: var(--space-md);
    border-radius: var(--radius-lg);
    background:
      linear-gradient(135deg, rgba(143, 245, 210, 0.07), transparent 46%),
      rgba(255, 255, 255, 0.06);
  }

  .record-facts dt {
    color: var(--color-text-muted);
    font-size: 0.68rem;
    font-weight: 900;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .record-facts dd {
    margin-top: 0.25rem;
    font-size: 1.45rem;
    font-family: var(--font-display);
    color: var(--color-white);
  }

  .record-layout {
    display: grid;
    grid-template-columns: 260px minmax(0, 1fr);
    gap: var(--space-2xl);
    align-items: start;
    padding-top: var(--space-4xl);
  }

  .record-sidebar {
    position: sticky;
    top: 6.25rem;
    border-radius: var(--radius-2xl);
    padding: var(--space-lg);
  }

  .record-sidebar nav {
    display: grid;
    gap: 0.35rem;
    margin-bottom: var(--space-lg);
  }

  .record-sidebar a {
    padding: 0.72rem 0;
    color: var(--color-text-secondary);
    border-bottom: 1px solid rgba(255, 255, 255, 0.07);
    font-weight: 800;
  }

  .record-sidebar a:hover {
    color: var(--color-green-bright);
  }

  .sidebar-scents {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
  }

  .record-main {
    min-width: 0;
  }

  .record-section {
    margin-bottom: var(--space-4xl);
    scroll-margin-top: 7rem;
  }

  .record-story,
  .caption-block {
    border-radius: var(--radius-2xl);
    padding: clamp(1.25rem, 4vw, 2.5rem);
    overflow: hidden;
  }

  .record-story::after,
  .caption-block::after {
    content: '';
    position: absolute;
    width: 24rem;
    height: 12rem;
    right: -8rem;
    top: -4rem;
    border-radius: 50%;
    background: radial-gradient(ellipse, rgba(169, 140, 255, 0.12), transparent 70%);
    filter: blur(20px);
    pointer-events: none;
  }

  .record-section-heading {
    margin-bottom: var(--space-xl);
  }

  .record-section-heading h2 {
    margin: var(--space-sm) 0;
  }

  .record-section-heading p {
    color: var(--color-text-secondary);
  }

  .kitchen-menu-link {
    margin: 0 0 var(--space-xl);
  }

  .prose {
    font-size: 1.05rem;
    line-height: 1.9;
    color: var(--color-text-secondary);
  }

  .prose :global(h2),
  .prose :global(h3) {
    margin-top: var(--space-2xl);
    margin-bottom: var(--space-md);
    color: var(--color-text-heading);
  }

  .prose :global(p) {
    margin-bottom: var(--space-md);
  }

  .prose :global(strong) {
    color: var(--color-text-heading);
  }

  .group-shot {
    margin-top: var(--space-2xl);
    border-radius: var(--radius-2xl);
    overflow: hidden;
    border: 1px solid var(--glass-border);
    background: var(--color-surface);
    aspect-ratio: 16 / 9;
    box-shadow: var(--glass-shadow);
  }

  .group-shot img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .caption-quote {
    padding: var(--space-lg);
    border-radius: var(--radius-xl);
    background: rgba(255, 255, 255, 0.06);
    color: var(--color-text-secondary);
    font-style: italic;
    line-height: 1.75;
  }

  .hashtags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: var(--space-lg);
  }

  .related-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: var(--space-lg);
  }

  @media (max-width: 1020px) {
    .record-hero-inner,
    .record-layout,
    .related-grid {
      grid-template-columns: 1fr;
    }

    .record-sidebar {
      position: relative;
      top: auto;
    }
  }

  @media (max-width: 640px) {
    .record-hero {
      min-height: auto;
      padding: 7rem 0 var(--space-3xl);
    }

    .record-title-block h1 {
      font-size: clamp(3rem, 16vw, 4.8rem);
    }

    .record-facts dl {
      grid-template-columns: 1fr;
    }
  }
</style>
