---
import { getAllBoxes } from '@/lib/content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import BoxCarousel from '@/components/BoxCarousel.astro';
import ScentProfile from '@/components/ScentProfile.astro';
import CTABlock from '@/components/CTABlock.astro';

const allBoxes = (await getAllBoxes())
  .filter((box) => !box.data.draft)
  .sort((a, b) => {
    const dateA = a.data.publishedDate?.getTime() ?? 0;
    const dateB = b.data.publishedDate?.getTime() ?? 0;
    return dateB - dateA;
  });

const latestBox = allBoxes[0];

// Grab up to 5 products from the latest box for floating pills
const heroProducts = latestBox?.data.products?.slice(0, 5) ?? [];
// Use group shot first, fall back to hero image
const heroImage = latestBox?.data.groupShot || latestBox?.data.heroImage;
// Split title for word-by-word reveal
const heroTitle = 'Inside the Lush Kitchen Box';
const heroWords = heroTitle.split(' ');
---

<BaseLayout title="Home">
  <!-- ================================
       Home Hero — image-driven, playful
       ================================ -->
  <section class="home-hero">
    <!-- Background image -->
    <div class="home-hero-bg">
      {heroImage ? (
        <img src={heroImage} alt={latestBox?.data.title ?? 'Lush Kitchen box contents'} class="home-hero-image" />
      ) : (
        <div class="home-hero-fallback"></div>
      )}
      <div class="home-hero-gradient"></div>
    </div>

    <!-- Floating product pills -->
    {heroProducts.length > 0 && (
      <div class="home-hero-floats" aria-hidden="true">
        {heroProducts.map((p, i) => (
          <span class="float-pill" data-float={i}>{p.name}</span>
        ))}
      </div>
    )}

    <!-- Content overlay -->
    <div class="container home-hero-content">
      <span class="home-hero-tag">Fan Archive</span>
      <h1 class="home-hero-title">
        {heroWords.map((word) => (
          <span class="hw-mask"><span class="hw">{word}&nbsp;</span></span>
        ))}
      </h1>
      <p class="home-hero-subtitle">
        Unboxings, product highlights, and nostalgic Lush favourites since 2022.
      </p>
      <div class="home-hero-actions">
        {latestBox && (
          <a href={`/kitchen-boxes/${latestBox.id}/`} class="btn btn--primary">Latest Box</a>
        )}
        <a href="/kitchen-boxes/" class="btn btn--secondary">Browse Archive</a>
      </div>
    </div>
  </section>

  <!-- Latest Kitchen Box — Scroll Scene -->
  {latestBox && (
    <section class="latest-box-scene section--alt" data-glow="green">
      <div class="container">
        <div class="latest-scene-stage">
          <div class="latest-scene-image">
            {latestBox.data.heroImage ? (
              <img src={latestBox.data.heroImage} alt={latestBox.data.title} />
            ) : (
              <div class="latest-scene-placeholder">
                <span>{latestBox.data.month} '{String(latestBox.data.year).slice(2)}</span>
              </div>
            )}
            <div class="latest-scene-overlay">
              <span class="latest-scene-label">Latest Box</span>
              <h3>{latestBox.data.title}</h3>
              <span class="latest-scene-date">{latestBox.data.month} {latestBox.data.year}</span>
            </div>
          </div>

          <p class="latest-scene-summary">{latestBox.data.summary}</p>

          {latestBox.data.products && latestBox.data.products.length > 0 && (
            <div class="latest-scene-products">
              {latestBox.data.products.slice(0, 5).map((p) => (
                <div class="scene-product">
                  <span class="scene-product-name">{p.name}</span>
                  {p.scent && <span class="scene-product-scent">{p.scent}</span>}
                </div>
              ))}
            </div>
          )}

          <a href={`/kitchen-boxes/${latestBox.id}/`} class="btn btn--primary latest-scene-cta">
            View full box details →
          </a>
        </div>
      </div>
    </section>
  )}

  <!-- Scent Profile -->
  {latestBox?.data.products && latestBox.data.products.length > 0 && (
    <ScentProfile
      products={latestBox.data.products}
      month={latestBox.data.month}
      year={latestBox.data.year}
    />
  )}

  <!-- Box Carousel -->
  {allBoxes.length > 0 && (
    <BoxCarousel
      boxes={allBoxes.map((box) => ({
        title: box.data.title,
        slug: box.id,
        month: box.data.month,
        year: box.data.year,
        summary: box.data.summary,
        heroImage: box.data.heroImage,
        productCount: box.data.products?.length,
      }))}
    />
  )}

  <!-- TikTok CTA -->
  <CTABlock
    title="Watch on TikTok"
    description="Monthly unboxings, bath demos, and first impressions from @lushiesam."
    primaryLink="https://www.tiktok.com/@lushiesam"
    primaryLabel="Follow @lushiesam"
    secondaryLink="/kitchen-boxes/"
    secondaryLabel="Browse the Archive"
  />
</BaseLayout>

<style>
  /* ========================================
     Home Hero — visual, playful, sensory
     ======================================== */
  .home-hero {
    position: relative;
    min-height: 92vh;
    display: flex;
    align-items: flex-end;
    overflow: hidden;
  }

  /* Background image layer */
  .home-hero-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .home-hero-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 40%;
  }

  .home-hero-fallback {
    width: 100%;
    height: 100%;
    background: var(--gradient-hero);
  }

  .home-hero-gradient {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(180deg, rgba(14, 17, 15, 0.25) 0%, rgba(14, 17, 15, 0.1) 30%, rgba(14, 17, 15, 0.6) 65%, rgba(14, 17, 15, 0.95) 100%),
      linear-gradient(90deg, rgba(14, 17, 15, 0.5) 0%, transparent 60%);
  }

  /* Content overlay */
  .home-hero-content {
    position: relative;
    z-index: 2;
    padding-bottom: var(--space-4xl);
    max-width: 640px;
  }

  .home-hero-tag {
    display: inline-block;
    font-family: var(--font-body);
    font-size: 0.6875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-green-bright);
    margin-bottom: var(--space-md);
    padding: 0.25rem 0.65rem;
    background: rgba(90, 138, 106, 0.15);
    border: 1px solid rgba(90, 138, 106, 0.25);
    border-radius: var(--radius-full);
  }

  .home-hero-title {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 6vw, 4rem);
    font-weight: 400;
    line-height: 1.1;
    color: var(--color-white);
    margin-bottom: var(--space-lg);
  }

  .hw-mask {
    display: inline-block;
    overflow: hidden;
    vertical-align: bottom;
  }

  .hw {
    display: inline-block;
  }

  .home-hero-subtitle {
    font-size: clamp(1rem, 2vw, 1.125rem);
    color: var(--color-text-secondary);
    line-height: 1.7;
    max-width: 480px;
    margin-bottom: var(--space-xl);
  }

  .home-hero-actions {
    display: flex;
    gap: var(--space-md);
    flex-wrap: wrap;
  }

  /* Floating product pills */
  .home-hero-floats {
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
  }

  .float-pill {
    position: absolute;
    padding: 0.35rem 0.85rem;
    border-radius: var(--radius-full);
    font-family: var(--font-body);
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--color-white);
    background: rgba(26, 32, 27, 0.55);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1px solid rgba(255, 255, 255, 0.1);
    white-space: nowrap;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.3);
  }

  /* Scatter positions — right side and top of hero */
  .float-pill[data-float="0"] { top: 20%; right: 10%; }
  .float-pill[data-float="1"] { top: 38%; right: 5%; }
  .float-pill[data-float="2"] { top: 55%; right: 14%; }
  .float-pill[data-float="3"] { top: 15%; right: 30%; }
  .float-pill[data-float="4"] { top: 42%; right: 25%; }

  /* ========================================
     Latest Box Scene
     ======================================== */
  .latest-box-scene {
    position: relative;
    overflow: visible;
    padding: var(--space-3xl) 0;
  }

  .latest-scene-stage {
    display: flex;
    flex-direction: column;
    gap: var(--space-xl);
  }

  .latest-scene-image {
    position: relative;
    border-radius: var(--radius-lg);
    overflow: hidden;
    aspect-ratio: 16 / 9;
    background: var(--color-surface);
    box-shadow: var(--glass-shadow);
  }

  .latest-scene-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .latest-scene-overlay {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: var(--space-2xl);
    background: linear-gradient(transparent 0%, rgba(14, 17, 15, 0.85) 100%);
  }

  .latest-scene-label {
    font-size: 0.6875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-green-bright);
    display: block;
    margin-bottom: var(--space-xs);
  }

  .latest-scene-overlay h3 {
    font-size: clamp(1.5rem, 3vw, 2rem);
    color: var(--color-white);
    margin-bottom: var(--space-xs);
  }

  .latest-scene-date {
    font-size: 0.75rem;
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .latest-scene-summary {
    color: var(--color-text-secondary);
    font-size: 1rem;
    line-height: 1.7;
    max-width: 600px;
  }

  .latest-scene-products {
    display: flex;
    flex-direction: column;
    gap: 1px;
    background: var(--glass-border);
    border-radius: var(--radius-lg);
    overflow: hidden;
  }

  .scene-product {
    display: flex;
    align-items: baseline;
    gap: var(--space-md);
    padding: var(--space-md) var(--space-lg);
    background: var(--glass-bg);
    backdrop-filter: blur(var(--glass-blur));
    -webkit-backdrop-filter: blur(var(--glass-blur));
  }

  .scene-product-name {
    font-family: var(--font-display);
    font-size: 1rem;
    color: var(--color-text-heading);
  }

  .scene-product-scent {
    font-size: 0.8125rem;
    color: var(--color-text-muted);
    font-style: italic;
  }

  .latest-scene-cta {
    align-self: flex-start;
  }

  .latest-scene-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-display);
    font-size: 2rem;
    color: var(--color-text-muted);
    background: var(--gradient-warm);
  }

  /* ========================================
     Responsive
     ======================================== */
  @media (max-width: 768px) {
    .home-hero {
      min-height: 80vh;
    }

    .home-hero-content {
      padding-bottom: var(--space-2xl);
    }

    .home-hero-floats {
      display: none;
    }

    .latest-box-scene {
      padding: var(--space-2xl) 0;
    }

    .latest-scene-image {
      aspect-ratio: 4 / 3;
    }

    .scene-product {
      flex-direction: column;
      gap: var(--space-xs);
    }
  }
</style>
