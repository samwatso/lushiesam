---
import { getCollection } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import Hero from '@/components/Hero.astro';
import SectionHeading from '@/components/SectionHeading.astro';
import BoxCard from '@/components/BoxCard.astro';
import CTABlock from '@/components/CTABlock.astro';

const allBoxes = (await getCollection('kitchenBoxes'))
  .filter((box) => !box.data.draft)
  .sort((a, b) => {
    const dateA = a.data.publishedDate?.getTime() ?? 0;
    const dateB = b.data.publishedDate?.getTime() ?? 0;
    return dateB - dateA;
  });

const latestBox = allBoxes[0];
const recentBoxes = allBoxes.slice(0, 4);
---

<BaseLayout title="Home">
  <!-- Hero -->
  <Hero
    title="The Lush Kitchen Archive"
    tag="Unboxed. Documented. Archived."
    subtitle="A fan archive of Lush Kitchen boxes since 2022."
  >
    <a href="/kitchen-boxes/" class="btn btn--primary">Browse the Archive</a>
    <a href="https://www.tiktok.com/@lushiesam" target="_blank" rel="noopener noreferrer" class="btn btn--secondary">
      Watch on TikTok
    </a>
  </Hero>

  <!-- Intro -->
  <section class="section">
    <div class="container container--narrow">
      <div class="intro-block" data-animate="stagger-children">
        <p>
          Documented boxes include product lists, scent notes, nostalgia context, and TikTok unboxings.
        </p>
        <p>
          Maintained by Sam
          (<a href="https://www.tiktok.com/@lushiesam" target="_blank" rel="noopener noreferrer">@lushiesam on TikTok</a>),
          a Kitchen subscriber since 2022.
        </p>
      </div>
    </div>
  </section>

  <!-- Latest Kitchen Box — Scroll Scene -->
  {latestBox && (
    <section class="latest-box-scene section--alt" data-glow="green">
      <div class="container">
        <div class="latest-scene-stage">
          <div class="latest-scene-image">
            {latestBox.data.heroImage ? (
              <img src={latestBox.data.heroImage} alt={latestBox.data.title} />
            ) : (
              <div class="latest-scene-placeholder">
                <span>{latestBox.data.month} '{String(latestBox.data.year).slice(2)}</span>
              </div>
            )}
            <div class="latest-scene-overlay">
              <span class="latest-scene-label">Latest Box</span>
              <h3>{latestBox.data.title}</h3>
              <span class="latest-scene-date">{latestBox.data.month} {latestBox.data.year}</span>
            </div>
          </div>

          <p class="latest-scene-summary">{latestBox.data.summary}</p>

          {latestBox.data.products && latestBox.data.products.length > 0 && (
            <div class="latest-scene-products">
              {latestBox.data.products.slice(0, 5).map((p) => (
                <div class="scene-product">
                  <span class="scene-product-name">{p.name}</span>
                  {p.scent && <span class="scene-product-scent">{p.scent}</span>}
                </div>
              ))}
            </div>
          )}

          <a href={`/kitchen-boxes/${latestBox.id}/`} class="btn btn--primary latest-scene-cta">
            View full box details →
          </a>
        </div>
      </div>
    </section>
  )}

  <!-- Archive Grid -->
  {recentBoxes.length > 1 && (
    <section class="section archive-section">
      <div class="container">
        <SectionHeading
          title="Archive"
          subtitle="Monthly unboxings, product notes, and nostalgic returns."
        />
        <div class="grid grid--2" data-animate="stagger-children" data-stagger="0.12">
          {recentBoxes.map((box) => (
            <BoxCard
              title={box.data.title}
              slug={box.id}
              month={box.data.month}
              year={box.data.year}
              summary={box.data.summary}
              heroImage={box.data.heroImage}
              productCount={box.data.products?.length}
            />
          ))}
        </div>
        <div style="margin-top: var(--space-2xl);">
          <a href="/kitchen-boxes/" class="btn btn--ghost">View all boxes →</a>
        </div>
      </div>
    </section>
  )}

  <!-- TikTok CTA -->
  <CTABlock
    title="Watch on TikTok"
    description="Monthly unboxings, bath demos, and first impressions from @lushiesam."
    primaryLink="https://www.tiktok.com/@lushiesam"
    primaryLabel="Follow @lushiesam"
    secondaryLink="/kitchen-boxes/"
    secondaryLabel="Browse the Archive"
  />
</BaseLayout>

<style>
  /* Intro block */
  .intro-block {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .intro-block p {
    color: var(--color-text-secondary);
    font-size: 1.0625rem;
    line-height: 1.8;
    max-width: none;
  }

  .intro-block a {
    color: var(--color-green-bright);
  }

  .intro-block a:hover {
    color: var(--color-white);
  }

  /* ========================================
     Latest Box Scene
     ======================================== */
  .latest-box-scene {
    position: relative;
    overflow: visible;
    padding: var(--space-3xl) 0;
  }

  .latest-scene-stage {
    display: flex;
    flex-direction: column;
    gap: var(--space-xl);
  }

  .latest-scene-image {
    position: relative;
    border-radius: var(--radius-lg);
    overflow: hidden;
    aspect-ratio: 16 / 9;
    background: var(--color-surface);
    box-shadow: var(--glass-shadow);
  }

  .latest-scene-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .latest-scene-overlay {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: var(--space-2xl);
    background: linear-gradient(transparent 0%, rgba(14, 17, 15, 0.85) 100%);
  }

  .latest-scene-label {
    font-size: 0.6875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-green-bright);
    display: block;
    margin-bottom: var(--space-xs);
  }

  .latest-scene-overlay h3 {
    font-size: clamp(1.5rem, 3vw, 2rem);
    color: var(--color-white);
    margin-bottom: var(--space-xs);
  }

  .latest-scene-date {
    font-size: 0.75rem;
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .latest-scene-summary {
    color: var(--color-text-secondary);
    font-size: 1rem;
    line-height: 1.7;
    max-width: 600px;
  }

  .latest-scene-products {
    display: flex;
    flex-direction: column;
    gap: 1px;
    background: var(--glass-border);
    border-radius: var(--radius-lg);
    overflow: hidden;
  }

  .scene-product {
    display: flex;
    align-items: baseline;
    gap: var(--space-md);
    padding: var(--space-md) var(--space-lg);
    background: var(--glass-bg);
    backdrop-filter: blur(var(--glass-blur));
    -webkit-backdrop-filter: blur(var(--glass-blur));
  }

  .scene-product-name {
    font-family: var(--font-display);
    font-size: 1rem;
    color: var(--color-text-heading);
  }

  .scene-product-scent {
    font-size: 0.8125rem;
    color: var(--color-text-muted);
    font-style: italic;
  }

  .latest-scene-cta {
    align-self: flex-start;
  }

  .latest-scene-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-display);
    font-size: 2rem;
    color: var(--color-text-muted);
    background: var(--gradient-warm);
  }

  @media (max-width: 768px) {
    .latest-box-scene {
      padding: var(--space-2xl) 0;
    }

    .latest-scene-image {
      aspect-ratio: 4 / 3;
    }

    .scene-product {
      flex-direction: column;
      gap: var(--space-xs);
    }
  }
</style>
