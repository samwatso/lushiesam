---
const currentYear = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container footer-row">
    <a href="/" class="footer-logo">LUSHIE SAM</a>

    <div class="footer-right">
      <nav class="footer-links" aria-label="Footer navigation">
        <a href="/kitchen-boxes/">Kitchen Boxes</a>
        <a href="/about/">About</a>
        <a href="https://www.tiktok.com/@lushiesam" target="_blank" rel="noopener noreferrer">TikTok</a>
      </nav>
      <p class="footer-disclaimer">Independent fan archive. Not affiliated with Lush Ltd.</p>
      <p class="footer-copyright">&copy; {currentYear} Lushie Sam</p>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    border-top: 1px solid var(--color-border);
    padding: var(--space-xl) 0;
    margin-top: var(--space-3xl);
  }

  .footer-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: var(--space-xl);
  }

  .footer-logo {
    font-family: var(--font-body);
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    color: var(--color-white);
    text-decoration: none;
    flex-shrink: 0;
  }

  .footer-logo:hover {
    color: var(--color-white);
  }

  .footer-right {
    display: flex;
    align-items: center;
    gap: var(--space-lg);
    flex-wrap: wrap;
    justify-content: flex-end;
  }

  .footer-links {
    display: flex;
    gap: var(--space-lg);
  }

  .footer-links a {
    color: var(--color-text-secondary);
    font-size: 0.8125rem;
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .footer-links a:hover {
    color: var(--color-green-bright);
  }

  .footer-disclaimer {
    font-size: 0.6875rem;
    font-style: italic;
    color: var(--color-text-muted);
  }

  .footer-copyright {
    font-size: 0.6875rem;
    color: var(--color-text-muted);
  }

  @media (max-width: 768px) {
    .footer-row {
      flex-direction: column;
      text-align: center;
      gap: var(--space-lg);
    }

    .footer-right {
      flex-direction: column;
      align-items: center;
      gap: var(--space-sm);
    }
  }
</style>
