---
import { ExternalLink } from '@lucide/astro';

const navItems = [
  { label: 'Home', href: '/' },
  { label: 'Boxes', href: '/kitchen-boxes/' },
  { label: 'Explore', href: '/explore/' },
  { label: 'Products', href: '/products/' },
  { label: 'Kitchen?', href: '/what-is-kitchen/' },
  { label: 'About', href: '/about/' },
];

const currentPath = Astro.url.pathname;
---

<header class="site-header">
  <div class="header-shell">
    <a href="/" class="logo" aria-label="Lushie Sam, Home">
      <span class="logo-mark" aria-hidden="true">LS</span>
      <span class="logo-copy">
        <span class="logo-text">Lushie Sam</span>
        <span class="logo-subtext">Fan archive</span>
      </span>
    </a>

    <button class="mobile-toggle" aria-label="Toggle menu" aria-expanded="false">
      <span class="hamburger"></span>
    </button>

    <nav class="main-nav" aria-label="Main navigation">
      <ul class="nav-list">
        {navItems.map(({ label, href }) => (
          <li>
            <a
              href={href}
              class:list={['nav-link', { active: currentPath === href || (href !== '/' && currentPath.startsWith(href)) }]}
            >
              {label}
            </a>
          </li>
        ))}
        <li>
          <a
            href="https://www.tiktok.com/@lushiesam"
            target="_blank"
            rel="noopener noreferrer"
            class="nav-link nav-link--external"
          >
            TikTok <ExternalLink size={13} stroke-width={2} />
          </a>
        </li>
      </ul>
    </nav>
  </div>
</header>

<script>
  const toggle = document.querySelector('.mobile-toggle');
  const nav = document.querySelector('.main-nav');
  const links = nav?.querySelectorAll('a');

  function setOpen(open: boolean) {
    toggle?.setAttribute('aria-expanded', String(open));
    nav?.classList.toggle('is-open', open);
    document.body.classList.toggle('nav-open', open);
  }

  toggle?.addEventListener('click', () => {
    const expanded = toggle.getAttribute('aria-expanded') === 'true';
    setOpen(!expanded);
  });

  links?.forEach((link) => {
    link.addEventListener('click', () => setOpen(false));
  });
</script>

<style>
  .site-header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    padding: 0.85rem var(--space-lg);
    pointer-events: none;
  }

  .header-shell {
    width: min(100%, var(--max-width));
    min-height: 4rem;
    margin: 0 auto;
    padding: 0.42rem 0.48rem 0.42rem 0.7rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-md);
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: var(--radius-full);
    background: rgba(8, 11, 14, 0.58);
    box-shadow: 0 18px 80px rgba(0, 0, 0, 0.28), inset 0 1px 0 rgba(255, 255, 255, 0.12);
    backdrop-filter: blur(26px) saturate(1.35);
    -webkit-backdrop-filter: blur(26px) saturate(1.35);
    pointer-events: auto;
  }

  .logo {
    display: inline-flex;
    align-items: center;
    gap: 0.72rem;
    color: var(--color-white);
    min-width: max-content;
  }

  .logo:hover {
    color: var(--color-white);
  }

  .logo-mark {
    width: 2.45rem;
    height: 2.45rem;
    display: grid;
    place-items: center;
    border-radius: 50%;
    font-size: 0.72rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    color: #06100b;
    background: var(--gradient-accent);
    box-shadow: 0 0 32px rgba(184, 255, 208, 0.2);
  }

  .logo-copy {
    display: flex;
    flex-direction: column;
    gap: 0.08rem;
  }

  .logo-text {
    font-size: 0.82rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .logo-subtext {
    font-size: 0.65rem;
    color: var(--color-text-muted);
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .nav-list {
    display: flex;
    list-style: none;
    align-items: center;
    gap: 0.18rem;
  }

  .nav-link {
    display: inline-flex;
    align-items: center;
    gap: 0.32rem;
    min-height: 2.65rem;
    padding: 0 0.9rem;
    border-radius: var(--radius-full);
    font-size: 0.74rem;
    font-weight: 800;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--color-text-secondary);
    transition: color 0.2s ease, background 0.2s ease, box-shadow 0.2s ease;
  }

  .nav-link:hover {
    color: var(--color-white);
    background: rgba(255, 255, 255, 0.07);
  }

  .nav-link.active {
    color: #06100b;
    background: rgba(247, 245, 239, 0.92);
    box-shadow: 0 12px 35px rgba(247, 245, 239, 0.14);
  }

  .nav-link--external svg {
    opacity: 0.62;
  }

  .mobile-toggle {
    display: none;
    width: 2.65rem;
    height: 2.65rem;
    border: 1px solid rgba(255, 255, 255, 0.11);
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.06);
    cursor: pointer;
  }

  .hamburger,
  .hamburger::before,
  .hamburger::after {
    display: block;
    width: 18px;
    height: 1.5px;
    margin: 0 auto;
    background: var(--color-white);
    border-radius: 1px;
    transition: all 0.25s ease;
  }

  .hamburger {
    position: relative;
  }

  .hamburger::before,
  .hamburger::after {
    content: '';
    position: absolute;
    left: 0;
    right: 0;
  }

  .hamburger::before { top: -5px; }
  .hamburger::after { top: 5px; }

  .mobile-toggle[aria-expanded="true"] .hamburger {
    background: transparent;
  }

  .mobile-toggle[aria-expanded="true"] .hamburger::before {
    top: 0;
    transform: rotate(45deg);
  }

  .mobile-toggle[aria-expanded="true"] .hamburger::after {
    top: 0;
    transform: rotate(-45deg);
  }

  @media (max-width: 980px) {
    .site-header {
      padding: 0.7rem var(--space-md);
    }

    .header-shell {
      min-height: 3.75rem;
      border-radius: var(--radius-xl);
    }

    .logo-subtext {
      display: none;
    }

    .mobile-toggle {
      display: block;
      flex: 0 0 auto;
    }

    .main-nav {
      position: fixed;
      top: 5rem;
      left: var(--space-md);
      right: var(--space-md);
      padding: var(--space-md);
      border: 1px solid rgba(255, 255, 255, 0.13);
      border-radius: var(--radius-2xl);
      background: rgba(8, 11, 14, 0.9);
      box-shadow: var(--shadow-lg);
      backdrop-filter: blur(28px) saturate(1.25);
      -webkit-backdrop-filter: blur(28px) saturate(1.25);
      opacity: 0;
      transform: translateY(-0.5rem) scale(0.98);
      pointer-events: none;
      transition: opacity 0.25s ease, transform 0.25s ease;
    }

    .main-nav.is-open {
      opacity: 1;
      transform: translateY(0) scale(1);
      pointer-events: auto;
    }

    .nav-list {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 0.5rem;
    }

    .nav-link {
      width: 100%;
      justify-content: center;
      min-height: 3.1rem;
      background: rgba(255, 255, 255, 0.055);
    }
  }

  @media (max-width: 430px) {
    .logo-mark {
      width: 2.25rem;
      height: 2.25rem;
    }

    .logo-text {
      font-size: 0.76rem;
    }
  }
</style>
